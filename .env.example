# Copy this file to .env and fill in your values. The .env file is gitignored
# and must never be committed.

# Required. The keyId shown in Intersight when you create a v3 API key.
# Format: <account_moid>/<user_moid>/<key_moid>
INTERSIGHT_API_KEY_ID=

# Required. Path to the .pem file you downloaded when generating the key.
INTERSIGHT_API_KEY_FILE=./intersight_api_key.pem

# Optional. Override only if you use Intersight Virtual Appliance (on-prem).
# INTERSIGHT_BASE_URL=https://your-appliance.example.com

# Optional. The script auto-fetches the account name from
# /api/v1/iam/Accounts. If your API key role can't read that endpoint, set
# the name explicitly here and it'll be used in the report title.
# INTERSIGHT_ACCOUNT_NAME=My Company
